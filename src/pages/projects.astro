---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";

const categories = [
  {
    name: "AI",
    projects: [
      {
        name: "llama2.zig",
        url: "https://github.com/donge/llama2.zig",
        desc: "Zig 实现的 llama2.c 复刻版，从零推理 LLaMA2 模型",
        lang: "Zig",
        stars: 6,
      },
      {
        name: "gguf_inspector",
        url: "https://github.com/donge/gguf_inspector",
        desc: "GGUF 模型文件结构解析工具，快速查看元数据与 tensor 信息",
        lang: "Rust",
        stars: 2,
      },
      {
        name: "soclaw",
        url: "https://github.com/donge/soclaw",
        desc: "Security Operation Claw — 安全运营平台",
        lang: "Go",
        stars: 0,
      },
    ],
  },
  {
    name: "网络",
    projects: [
      {
        name: "wfilter",
        url: "https://github.com/donge/wfilter",
        desc: "基于 DPDK + Aho-Corasick 的高性能 Web 关键词防火墙",
        lang: "C",
        stars: 9,
      },
      {
        name: "wfilter-front",
        url: "https://github.com/donge/wfilter-front",
        desc: "wFilter 前端管理界面",
        lang: "CSS",
        stars: 1,
      },
      {
        name: "wfilter-back",
        url: "https://github.com/donge/wfilter-back",
        desc: "wFilter 后端服务",
        lang: "JavaScript",
        stars: 1,
      },
      {
        name: "go-yyjson",
        url: "https://github.com/donge/go-yyjson",
        desc: "yyjson 的 Go 绑定，高性能 JSON 解析",
        lang: "C",
        stars: 3,
      },
      {
        name: "ips",
        url: "https://github.com/donge/ips",
        desc: "IP 地理位置查询工具",
        lang: "Go",
        stars: 0,
      },
    ],
  },
  {
    name: "量化",
    projects: [
      {
        name: "tdx_ext",
        url: "https://github.com/donge/tdx_ext",
        desc: "通达信行情数据 DuckDB 扩展，SQL 接口读取 .lc1/.lc5/.day 格式",
        lang: "C++",
        stars: 0,
      },
      {
        name: "xiaoshaozi",
        url: "https://github.com/donge/xiaoshaozi",
        desc: "Bitcoin 自动交易框架",
        lang: "Go",
        stars: 25,
      },
      {
        name: "fxbtc",
        url: "https://github.com/donge/fxbtc",
        desc: "比特币跨交易所套利工具",
        lang: "Go",
        stars: 3,
      },
      {
        name: "chbtc",
        url: "https://github.com/donge/chbtc",
        desc: "chbtc.com 比特币交易 Python API",
        lang: "Python",
        stars: 5,
      },
      {
        name: "dashuner",
        url: "https://github.com/donge/dashuner",
        desc: "股票数据获取与分析工具",
        lang: "Python",
        stars: 2,
      },
    ],
  },
  {
    name: "其他",
    projects: [
      {
        name: "copull",
        url: "https://github.com/donge/copull",
        desc: "靠谱日报 APP，基于 Ionic 框架",
        lang: "TypeScript",
        stars: 0,
      },
      {
        name: "dailyReport",
        url: "https://github.com/donge/dailyReport",
        desc: "日报系统",
        lang: "JavaScript",
        stars: 0,
      },
      {
        name: "gnats",
        url: "https://github.com/donge/gnats",
        desc: "GNATS 爬虫、API 及客户端",
        lang: "Python",
        stars: 1,
      },
      {
        name: "syncheck",
        url: "https://github.com/donge/syncheck",
        desc: "检查 PR commit 是否已合入所有 SVN 分支的工具",
        lang: "Python",
        stars: 1,
      },
      {
        name: "duv",
        url: "https://github.com/donge/duv",
        desc: "磁盘使用可视化工具",
        lang: "HTML",
        stars: 0,
      },
      {
        name: "donge",
        url: "https://github.com/donge/donge",
        desc: "电脑爱好者的旧代码",
        lang: "ASP",
        stars: 0,
      },
    ],
  },
];

const langColor: Record<string, string> = {
  Zig: "#ec915c",
  Rust: "#dea584",
  Go: "#00add8",
  C: "#555555",
  "C++": "#f34b7d",
  Python: "#3572a5",
  JavaScript: "#f1e05a",
  TypeScript: "#3178c6",
  CSS: "#563d7c",
  HTML: "#e34c26",
  ASP: "#6a40fd",
};
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section class="mb-28 max-w-app">
      <h1 class="text-2xl tracking-wider sm:text-3xl mb-8">Projects</h1>
      {
        categories.map(cat => (
          <div class="mb-10">
            <h2 class="text-accent font-mono text-sm font-semibold uppercase tracking-widest mb-4 border-b border-border pb-2">
              ## {cat.name}
            </h2>
            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
              {cat.projects.map(p => (
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded border border-border bg-card p-4 transition-colors hover:border-accent hover:bg-card/80"
                >
                  <div class="flex items-start justify-between gap-2">
                    <span class="font-mono text-sm font-semibold text-foreground group-hover:text-accent transition-colors">
                      {p.name}
                    </span>
                    {p.stars > 0 && (
                      <span class="shrink-0 font-mono text-xs text-muted-foreground">
                        ★ {p.stars}
                      </span>
                    )}
                  </div>
                  <p class="mt-1 text-xs text-muted-foreground leading-relaxed">
                    {p.desc}
                  </p>
                  <div class="mt-3 flex items-center gap-1.5">
                    <span
                      class="inline-block size-2.5 rounded-full shrink-0"
                      style={`background-color: ${langColor[p.lang] ?? "#888"}`}
                    />
                    <span class="font-mono text-xs text-muted-foreground">
                      {p.lang}
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </section>
  </main>
  <Footer />
</Layout>
